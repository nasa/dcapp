<?xml version="1.0"?>
<DCAPP>
    <!-- Valid variable -->
    <Variable Type="#_variable_double_" InitialValue="0">GOOD_VAR</Variable>

    <!-- Invalid attribute "Rotation" on Variable (Rotation is for shapes, not variables) -->
    <Variable Type="#_variable_double_" Rotation="45" InitialValue="0">ROTATED_VAR</Variable>

    <!-- Invalid variable type value -->
    <Variable Type="99" InitialValue="0">BAD_TYPE_VAR</Variable>

    <Window Title="Bad Sample Test" X="30" Y="30" Width="800" Height="600">
        <Panel VirtualWidth="800" VirtualHeight="600">

            <!-- Invalid attribute "Radius" on Rectangle (Radius is for Circle, not Rectangle) -->
            <Rectangle X="100" Y="100" Width="200" Height="100" Radius="50" FillColor="1 0 0"/>

            <!-- Invalid attribute "File" on Text (File is for Image, not Text) -->
            <Text X="200" Y="300" File="test.txt" FillColor="1 1 1">Hello World</Text>

            <!-- Valid elements for comparison -->
            <Ellipse X="500" Y="300" Radius="50" FillColor="0 0 1"/>
            <Text X="400" Y="400" Size="16" FillColor="1 1 1">Valid Text</Text>

            <!-- Invalid attribute "BackgroundColor" on Container (not a valid container attr) -->
            <Container X="600" Y="100" Width="100" Height="100" BackgroundColor="0.5 0.5 0.5">
                <Text X="50" Y="50">In container</Text>
            </Container>

            <!-- Invalid attribute "Segments" on Rectangle -->
            <Rectangle X="100" Y="400" Width="50" Height="50" Segments="32" FillColor="0 1 0"/>

            <!-- Invalid LocalAlignX value (should be 1-3, not 7) -->
            <Text X="300" Y="500" LocalAlignX="7" FillColor="1 1 1">Bad Align X</Text>

            <!-- Invalid LocalAlignY value (should be 4-6, not 1) -->
            <Text X="300" Y="550" LocalAlignY="1" FillColor="1 1 1">Bad Align Y</Text>

            <!-- Invalid Operation on If (should be 1-8, not 99) -->
            <If Value="@GOOD_VAR" Operation="99">
                <Text X="100" Y="100">Should not show</Text>
            </If>

            <!-- Invalid Operator on Set (should be 1-7, not 99) -->
            <Set Variable="@GOOD_VAR" Operator="99"/>

        </Panel>
    </Window>
</DCAPP>
