            <!-- RECTANGLES (upper section) -->
            <!-- ================================================================== -->
            <Text X="450" Y="620" Size="18" FillColor="0.6 0.8 1" LocalAlignX="#_align_center_">Rectangles: Rounded vs Normal</Text>

            <!-- Normal rectangle -->
            <Rectangle X="60" Y="460" Width="160" Height="120" FillColor="0.2 0.4 0.6" LineColor="0.4 0.7 1" LineWidth="2"/>
