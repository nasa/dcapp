<?xml version="1.0"?>
<DCAPP>
    <Window X="30" Y="30" Width="900" Height="700">
        <Panel VirtualWidth="900" VirtualHeight="700" BackgroundColor="0.1 0.1 0.15">

            <!-- Row 1: Basic Arcs with different angles (top row) -->
            <Text X="150" Y="670" Size="14" FillColor="1 1 1" LocalAlignX="#_align_center_">90 deg</Text>
            <Arc X="150" Y="570" Radius="80" Angle="90" Rotation="0" LineColor="1 0.5 0" LineWidth="4"/>

            <Text X="350" Y="670" Size="14" FillColor="1 1 1" LocalAlignX="#_align_center_">180 deg</Text>
            <Arc X="350" Y="570" Radius="80" Angle="180" Rotation="0" LineColor="0 0.8 0.2" LineWidth="4"/>

            <Text X="550" Y="670" Size="14" FillColor="1 1 1" LocalAlignX="#_align_center_">270 deg</Text>
            <Arc X="550" Y="570" Radius="80" Angle="270" Rotation="0" LineColor="0.2 0.6 1" LineWidth="4"/>

            <Text X="750" Y="670" Size="14" FillColor="1 1 1" LocalAlignX="#_align_center_">360 deg (full)</Text>
            <Arc X="750" Y="570" Radius="80" Angle="360" Rotation="0" LineColor="1 0.2 0.8" LineWidth="4"/>

            <!-- Row 2: Arcs with different rotations -->
            <Text X="150" Y="470" Size="14" FillColor="1 1 1" LocalAlignX="#_align_center_">Rot: 0</Text>
            <Arc X="150" Y="370" Radius="70" Angle="90" Rotation="0" LineColor="1 1 0" LineWidth="3"/>

            <Text X="350" Y="470" Size="14" FillColor="1 1 1" LocalAlignX="#_align_center_">Rot: 45</Text>
            <Arc X="350" Y="370" Radius="70" Angle="90" Rotation="45" LineColor="1 1 0" LineWidth="3"/>

            <Text X="550" Y="470" Size="14" FillColor="1 1 1" LocalAlignX="#_align_center_">Rot: 90</Text>
            <Arc X="550" Y="370" Radius="70" Angle="90" Rotation="90" LineColor="1 1 0" LineWidth="3"/>

            <Text X="750" Y="470" Size="14" FillColor="1 1 1" LocalAlignX="#_align_center_">Rot: 180</Text>
            <Arc X="750" Y="370" Radius="70" Angle="90" Rotation="180" LineColor="1 1 0" LineWidth="3"/>

            <!-- Row 3: Pie mode comparison -->
            <Text X="150" Y="270" Size="14" FillColor="1 1 1" LocalAlignX="#_align_center_">Pie=false (default)</Text>
            <Arc X="150" Y="170" Radius="70" Angle="120" Rotation="0" LineColor="0.8 0.2 0.8" LineWidth="3" Pie="false"/>

            <Text X="350" Y="270" Size="14" FillColor="1 1 1" LocalAlignX="#_align_center_">Pie=true (outline)</Text>
            <Arc X="350" Y="170" Radius="70" Angle="120" Rotation="0" LineColor="0.8 0.2 0.8" LineWidth="3" Pie="true"/>

            <Text X="550" Y="270" Size="14" FillColor="1 1 1" LocalAlignX="#_align_center_">Pie + Fill</Text>
            <Arc X="550" Y="170" Radius="70" Angle="120" Rotation="0" FillColor="0.4 0.1 0.4" LineColor="0.8 0.2 0.8" LineWidth="3" Pie="true"/>

            <Text X="750" Y="270" Size="14" FillColor="1 1 1" LocalAlignX="#_align_center_">Pie + Fill only</Text>
            <Arc X="750" Y="170" Radius="70" Angle="120" Rotation="0" FillColor="0.2 0.5 0.3" Pie="true"/>

            <!-- Row 4: Fun examples (bottom row) -->
            <Text X="150" Y="120" Size="12" FillColor="1 1 1" LocalAlignX="#_align_center_">Pacman</Text>
            <Arc X="150" Y="70" Radius="40" Angle="300" Rotation="-90" FillColor="1 1 0" Pie="true"/>

            <Text X="350" Y="120" Size="12" FillColor="1 1 1" LocalAlignX="#_align_center_">Gauge</Text>
            <Arc X="350" Y="60" Radius="50" Angle="180" Rotation="90" LineColor="0.3 0.3 0.3" LineWidth="8"/>
            <Arc X="350" Y="60" Radius="50" Angle="120" Rotation="90" LineColor="0 1 0" LineWidth="8"/>

            <Text X="550" Y="120" Size="12" FillColor="1 1 1" LocalAlignX="#_align_center_">Meter</Text>
            <Arc X="550" Y="60" Radius="50" Angle="180" Rotation="90" LineColor="0.5 0.5 0.5" LineWidth="6"/>
            <Arc X="550" Y="60" Radius="50" Angle="60" Rotation="90" LineColor="1 0 0" LineWidth="6"/>
            <Arc X="550" Y="60" Radius="50" Angle="60" Rotation="150" LineColor="1 1 0" LineWidth="6"/>
            <Arc X="550" Y="60" Radius="50" Angle="60" Rotation="210" LineColor="0 1 0" LineWidth="6"/>

            <Text X="750" Y="120" Size="12" FillColor="1 1 1" LocalAlignX="#_align_center_">Concentric</Text>
            <Arc X="750" Y="70" Radius="50" Angle="270" Rotation="45" LineColor="1 0.3 0.3" LineWidth="4"/>
            <Arc X="750" Y="70" Radius="40" Angle="270" Rotation="90" LineColor="0.3 1 0.3" LineWidth="4"/>
            <Arc X="750" Y="70" Radius="30" Angle="270" Rotation="135" LineColor="0.3 0.3 1" LineWidth="4"/>
        </Panel>
    </Window>
</DCAPP>
