<?xml version="1.0"?>
<DCAPP>
    <Variable Type="#_variable_double_" InitialValue="90">LATITUDE</Variable>
    <Variable Type="#_variable_double_" InitialValue="0">LONGITUDE</Variable>
    <Variable Type="#_variable_double_" InitialValue="1">ZOOM</Variable>
    <Variable Type="#_variable_integer_" InitialValue="0">CLEAR_TRAILS</Variable>
    <Variable Type="#_variable_integer_" InitialValue="0">CURR_DISPLAY_TEXTURE</Variable>

    <!-- UTM constants -->
    <Constant Name="LonMin">0</Constant>
    <Constant Name="LonMax">360</Constant>
    <Constant Name="LatMin">87.5</Constant>
    <Constant Name="LatMax">90</Constant>

    <Constant Name="BgColor">0 0 0</Constant>
    <Variable Type="#_variable_integer_">ZoomSelected</Variable>
    <Variable Type="#_variable_double_" InitialValue="1">ZoomSlider</Variable>
    <Variable Type="#_variable_integer_">ClearTrailsSelected</Variable>
    <Variable Type="#_variable_integer_">LayerSwapSelected</Variable>

    <Default>
        <Text ForceMono="Numeric" ParentAlignX="#_align_center_" ParentAlignY="#_align_middle_" LocalAlignX="#_align_center_" LocalAlignY="#_align_middle_" Size="100" FillColor="1 1 1" LineColor="0 0 0"/>
        <Button Type="#_button_momentary_" Width="2000" Height="100" ParentAlignX="#_align_center_" ParentAlignY="#_align_middle_" LocalAlignX="#_align_center_" LocalAlignY="#_align_middle_"/>
        <Rectangle LineColor=".5 .5 .5" ParentAlignX="#_align_center_" ParentAlignY="#_align_middle_" LocalAlignX="#_align_center_" LocalAlignY="#_align_middle_" LineWidth="2.0" FillColor=".5 .5 .5"/>
        <Container X="1250" Width="1250" Height="5" LocalAlignX="#_align_center_" LocalAlignY="#_align_middle_"/>
    </Default>

    <Window X="30" Y="30" Width="600" Height="800">
        <Panel VirtualWidth="1275" VirtualHeight="1667" BackgroundColor="#BgColor">

            <!-- TODO: Map element not yet implemented -->
            <!--
            <Map Latitude="@LATITUDE" Longitude="@LONGITUDE" Zoom="@ZOOM" TrailWidth="5" TrailColor="1 0 0 .7"
                    EnableIcon="1" EnableTrail="1" FnClearTrail="@CLEAR_TRAILS" 
                    X="50" Y="275"
                    IconFile="images/chevron.tga" IconWidth="50" IconHeight="65" IconRotationOffset="-90" TextureIndex="@CURR_DISPLAY_TEXTURE"
                    Width="1175" Height="1175" LocalAlignX="#_align_left_" LocalAlignY="#_align_bottom_" EnableCircularMap="1"
                    ZoneLon1="100" ZoneLon2="120" ZoneLon3="120" ZoneLon4="100" ZoneLat1="89" ZoneLat2="89" ZoneLat3="89.5" ZoneLat4="89.5">
                    <UPSMapTexture File="images/moon1.s3tc" Index="0"
                        TopLeftLatitude="87.5" TopLeftLongitude="-45"
                        BottomRightLatitude="87.5" BottomRightLongitude="135">
                        <MapImage File="images/square.tga" Width="250" Height="250" Latitude="89" Longitude="-135"/>
                        <MapImage File="images/triangle.tga" Width="100" Height="100" Latitude="88.8" Longitude="-45"/>
                        <MapString Size="50" Latitude="89" Longitude="0" Layers="0,1">ZONE01</MapString>    
                    </UPSMapTexture>

                    <UPSMapTexture File="images/moon2.s3tc" Index="1"
                        TopLeftLatitude="87.5" TopLeftLongitude="-45"
                        BottomRightLatitude="87.5" BottomRightLongitude="135">
                    </UPSMapTexture>
            </Map>
            -->
            <Rectangle X="50" Y="275" Width="1175" Height="1175" LocalAlignX="#_align_left_" LocalAlignY="#_align_bottom_" LineColor="1 0 0" LineWidth="2"/>
            <Text X="637" Y="862" LocalAlignX="#_align_center_" LocalAlignY="#_align_middle_" Size="80" FillColor="1 0 0">TODO: Map Element</Text>

            <!-- clear button -->
            <Button Type="#_button_momentary_" X="1000" Y="135" Width="100" Height="100" Variable="ClearTrailsSelected"/>
            <If Value1="@ClearTrailsSelected" Operation="#_conditional_true_">
                <Rectangle X="1000" Y="135" Width="100" Height="100" FillColor="1 .5 0.5"/>
                <Set Variable="CLEAR_TRAILS" Operator="#_set_add_">1</Set>
            </If>
            <If Value1="@ClearTrailsSelected" Operation="#_conditional_false_">
                <Rectangle X="1000" Y="135" Width="100" Height="100" FillColor=".5 .5 0.5"/>
            </If>

            <!-- layer swap button -->
            <Button Type="#_button_toggle_" X="1150" Y="135" Width="100" Height="100" Variable="CURR_DISPLAY_TEXTURE" On="1" Off="0">
                <ButtonIndicatorOn>
                    <Rectangle X="1150" Y="135" Width="100" Height="100" FillColor="1 .5 0.5"/>
                </ButtonIndicatorOn>
                <ButtonIndicatorOff>
                    <Rectangle X="1150" Y="135" Width="100" Height="100" FillColor=".5 .5 0.5"/>
                </ButtonIndicatorOff>
            </Button>

            <!-- lat/long -->
            <Text X="925" Y="1525" LocalAlignX="#_align_right_" Size="80">Lat:</Text>
            <Text X="1225" Y="1525" LocalAlignX="#_align_right_" Size="80">@LATITUDE(%.3f)</Text>
            <Text X="50" Y="1525" LocalAlignX="#_align_left_" Size="80">Lon:</Text>
            <Text X="250" Y="1525" LocalAlignX="#_align_left_" Size="80">@LONGITUDE(%.3f)</Text>

            <!-- ZOOM -->
            <Text X="100" Y="125" LocalAlignX="#_align_left_" Size="80">Zoom:</Text>
            <Text X="400" Y="125" LocalAlignX="#_align_left_" Size="80">@ZOOM(%.1f)</Text>

            <Container X="50" Y="50" VirtualWidth="10" Width="1175" LocalAlignX="#_align_left_" LocalAlignY="#_align_middle_">
                <Rectangle FillColor=".5 .5 .5"/>
                <Button Type="#_button_momentary_" X="@ZoomSlider" Width="10" Height="20" Variable="ZoomSelected"/>
                <If Value1="@ZoomSelected" Operation="#_conditional_true_">
                    <!-- TODO: MouseMotion element not yet implemented -->
                    <!-- <MouseMotion XVariable="ZoomSlider"/> -->
                    <If Value1="@ZoomSlider" Operation="#_conditional_gt_" Value2="10">
                        <Set Variable="ZoomSlider">10</Set>
                    </If>
                    <If Value1="@ZoomSlider" Operation="#_conditional_lt_" Value2="1">
                        <Set Variable="ZoomSlider">1</Set>
                    </If>
                    <Rectangle X="@ZoomSlider" Width="1" Height="20" FillColor="0.5 1 0.5"/>
                    <Set Variable="ZOOM">@ZoomSlider</Set>
                </If>
                <If Value1="@ZoomSelected" Operation="#_conditional_false_">
                    <If Value1="@ZoomSlider" Operation="#_conditional_gt_" Value2="10">
                        <Set Variable="ZoomSlider">10</Set>
                    </If>
                    <If Value1="@ZoomSlider" Operation="#_conditional_lt_" Value2="1">
                        <Set Variable="ZoomSlider">1</Set>
                    </If>
                    <Rectangle X="@ZoomSlider" Width="1" Height="20" FillColor="0.5 0.5 0.5"/>
                </If>
            </Container>

            <!-- TODO: KeyboardEvent element not yet implemented -->
            <!--
            <KeyboardEvent Key="w">
                <OnPress>
                    <Set Variable="LATITUDE" Operator="#_set_add_">.01</Set>
                </OnPress>
            </KeyboardEvent>
            <KeyboardEvent Key="a">
                <OnPress>
                    <Set Variable="LONGITUDE" Operator="#_set_subtract_">.36</Set>
                    <If Value1="@LONGITUDE" Operation="#_conditional_lt_" Value2="0">
                        <Set Variable="LONGITUDE">360</Set>
                    </If>
                </OnPress>
            </KeyboardEvent>
            <KeyboardEvent Key="s">
                <OnPress>
                    <Set Variable="LATITUDE" Operator="#_set_subtract_">.01</Set>
                </OnPress>
            </KeyboardEvent>
            <KeyboardEvent Key="d">
                <OnPress>
                    <Set Variable="LONGITUDE" Operator="#_set_add_">.36</Set>
                    <If Value1="@LONGITUDE" Operation="#_conditional_gt_" Value2="360">
                        <Set Variable="LONGITUDE">0</Set>
                    </If>
                </OnPress>
            </KeyboardEvent>
            -->

            <!-- Manual nav buttons as workaround for keyboard events -->
            <Button Type="#_button_momentary_" X="637" Y="200" Width="100" Height="50">
                <MousePressed><Set Variable="LATITUDE" Operator="#_set_add_">.01</Set></MousePressed>
                <ButtonIndicatorOn><Rectangle FillColor="0.3 0.5 0.3"/></ButtonIndicatorOn>
                <ButtonIndicatorOff><Rectangle FillColor="0.2 0.3 0.2"/></ButtonIndicatorOff>
                <Text Size="30">N</Text>
            </Button>
            <Button Type="#_button_momentary_" X="537" Y="125" Width="100" Height="50">
                <MousePressed>
                    <Set Variable="LONGITUDE" Operator="#_set_subtract_">.36</Set>
                    <If Value1="@LONGITUDE" Operation="#_conditional_lt_" Value2="0">
                        <Set Variable="LONGITUDE">360</Set>
                    </If>
                </MousePressed>
                <ButtonIndicatorOn><Rectangle FillColor="0.3 0.5 0.3"/></ButtonIndicatorOn>
                <ButtonIndicatorOff><Rectangle FillColor="0.2 0.3 0.2"/></ButtonIndicatorOff>
                <Text Size="30">W</Text>
            </Button>
            <Button Type="#_button_momentary_" X="637" Y="50" Width="100" Height="50">
                <MousePressed><Set Variable="LATITUDE" Operator="#_set_subtract_">.01</Set></MousePressed>
                <ButtonIndicatorOn><Rectangle FillColor="0.3 0.5 0.3"/></ButtonIndicatorOn>
                <ButtonIndicatorOff><Rectangle FillColor="0.2 0.3 0.2"/></ButtonIndicatorOff>
                <Text Size="30">S</Text>
            </Button>
            <Button Type="#_button_momentary_" X="737" Y="125" Width="100" Height="50">
                <MousePressed>
                    <Set Variable="LONGITUDE" Operator="#_set_add_">.36</Set>
                    <If Value1="@LONGITUDE" Operation="#_conditional_gt_" Value2="360">
                        <Set Variable="LONGITUDE">0</Set>
                    </If>
                </MousePressed>
                <ButtonIndicatorOn><Rectangle FillColor="0.3 0.5 0.3"/></ButtonIndicatorOn>
                <ButtonIndicatorOff><Rectangle FillColor="0.2 0.3 0.2"/></ButtonIndicatorOff>
                <Text Size="30">E</Text>
            </Button>
        </Panel>
    </Window>
</DCAPP>
