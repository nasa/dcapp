<?xml version="1.0"?>
<DCAPP>
    <Window X="30" Y="30" Width="640" Height="480">
        <Constant Name="BgColor">0 0 0</Constant>
        <Constant Name="FgColor">1 1 1</Constant>
        <Default>
            <Text Size="40" FillColor="#FgColor" ParentAlignX="#_align_center_" ParentAlignY="#_align_middle_" LocalAlignX="#_align_center_" LocalAlignY="#_align_middle_"/>
        </Default>

        <Panel VirtualWidth="1600" VirtualHeight="1200" BackgroundColor="#BgColor">
            <Text Y="900">\$USER = $USER</Text>
            <Text Y="850">\$LOGNAME = $LOGNAME</Text>
            <Text Y="800">\$HOME = $HOME</Text>
            <Text Y="750">\$HOSTTYPE = $HOSTTYPE</Text>
            <Text Y="700">\$VENDOR = $VENDOR</Text>
            <Text Y="650">\$OSTYPE = $OSTYPE</Text>
            <Text Y="600">\$MACHTYPE = $MACHTYPE</Text>
            <Text Y="550">\$HOST = $HOST</Text>
            <Text Y="460">\$dcappOSTYPE = $dcappOSTYPE</Text>
            <Text Y="410">\$dcappOSSPEC = $dcappOSSPEC</Text>
            <Text Y="360">\$dcappOBJDIR = $dcappOBJDIR</Text>
            <Text Y="310">\$dcappBINDIR = $dcappBINDIR</Text>
            <Text Y="260">\$dcappVERSION = $dcappVERSION</Text>
        </Panel>
    </Window>
</DCAPP>
