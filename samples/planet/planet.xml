<?xml version="1.0"?>
<DCAPP>
    <!-- Planet Demo -->
    <!-- Two identical planet views: XML geodetic view (left) vs logic geodetic view (right) -->

    <!-- Slider raw values (all 0-100 range, mapped to actual values via Set) -->
    <Variable Type="#_variable_double_" InitialValue="17.433">SliderLat</Variable>
    <Variable Type="#_variable_double_" InitialValue="95.908">SliderLon</Variable>
    <Variable Type="#_variable_double_" InitialValue="40">SliderEle</Variable>
    <Variable Type="#_variable_double_" InitialValue="0">SliderHdg</Variable>
    <Variable Type="#_variable_double_" InitialValue="30">SliderTau</Variable>
    <Variable Type="#_variable_double_" InitialValue="0">SliderLightY</Variable>

    <!-- Computed values -->
    <Variable Type="#_variable_double_" InitialValue="-58.62">Latitude</Variable>
    <Variable Type="#_variable_double_" InitialValue="345.27">Longitude</Variable>
    <Variable Type="#_variable_double_" InitialValue="2000000">Elevation</Variable>
    <Variable Type="#_variable_double_" InitialValue="0">Heading</Variable>
    <Variable Type="#_variable_double_" InitialValue="0.3">Tau</Variable>
    <Variable Type="#_variable_double_" InitialValue="-1">LightY</Variable>
    <Variable Type="#_variable_double_" InitialValue="-65">OrbitLat</Variable>
    <Variable Type="#_variable_double_" InitialValue="315">OrbitLon</Variable>

    <!-- Logic-facing readout text -->
    <Variable Type="#_variable_string_">LogicReadout</Variable>

    <!-- Button state variables -->
    <Variable Type="#_variable_integer_">SliderLatSelected</Variable>
    <Variable Type="#_variable_integer_">SliderLonSelected</Variable>
    <Variable Type="#_variable_integer_">SliderEleSelected</Variable>
    <Variable Type="#_variable_integer_">SliderHdgSelected</Variable>
    <Variable Type="#_variable_integer_">SliderTauSelected</Variable>
    <Variable Type="#_variable_integer_">SliderLightYSelected</Variable>

    <!-- Independent shader indices: 1=elevation, 2=slope -->
    <Variable Type="#_variable_integer_" InitialValue="1">LeftShader</Variable>
    <Variable Type="#_variable_integer_" InitialValue="2">RightShader</Variable>

    <!-- Orthographic projection toggle -->
    <Variable Type="#_variable_integer_" InitialValue="0">UseOrtho</Variable>

    <!-- Texture overlay -->
    <Variable Type="#_variable_integer_" InitialValue="0">TextureRefresh</Variable>
    <Variable Type="#_variable_double_" InitialValue="2000">TexMpp</Variable>

    <Logic File="logic/logic.so"/>

    <!-- Top-level planet definition (shared by both views) -->
    <Planet Name="Moon" CRS="#_planet_crs_geodetic_" MeshCacheSize="128" LightDirectionX="-1" LightDirectionY="@LightY" LightDirectionZ="-1">
        <PlanetData File="../../data/LDEM_45S_100M.planet.json"/>
        <PlanetTexture File="../../assets/nasa-worm.png" MetersPerPixel="@TexMpp"
            Latitude="-90" Longitude="180" FireRefresh="@TextureRefresh"/>
        <PlanetShader Index="1" FragmentShader="shaders/planet_elevation.frag"/>
        <PlanetShader Index="2" FragmentShader="shaders/planet_slope.frag"/>
        <PlanetShader Index="3" VertexShader="shaders/planet_flat.vert" FragmentShader="shaders/planet_elevation.frag"/>
    </Planet>

    <Default>
        <Text Size="14" FillColor="#_color_white_"/>
    </Default>

    <Window X="0" Y="20" Width="1000" Height="840" UpdateRate="60">
        <Panel VirtualWidth="1000" VirtualHeight="840" BackgroundColor="#_color_black_">

            <!-- Compute values from sliders (all sliders are 0-100) -->
            <Set Variable="Latitude">@SliderLat</Set>
            <Set Variable="Latitude" Operator="#_set_multiply_">1.8</Set>
            <Set Variable="Latitude" Operator="#_set_subtract_">90</Set>
            <Set Variable="Longitude">@SliderLon</Set>
            <Set Variable="Longitude" Operator="#_set_multiply_">3.6</Set>
            <Set Variable="Elevation">@SliderEle</Set>
            <Set Variable="Elevation" Operator="#_set_multiply_">50000</Set>
            <Set Variable="Heading">@SliderHdg</Set>
            <Set Variable="Heading" Operator="#_set_multiply_">3.6</Set>
            <Set Variable="Tau">@SliderTau</Set>
            <Set Variable="Tau" Operator="#_set_multiply_">0.01</Set>
            <Set Variable="LightY">@SliderLightY</Set>
            <Set Variable="LightY" Operator="#_set_multiply_">0.02</Set>
            <Set Variable="LightY" Operator="#_set_subtract_">1</Set>

            <!-- Toggle texture scale based on refresh state -->
            <If Value1="@TextureRefresh" Operator="#_if_eq_" Value2="0">
                <Set Variable="TexMpp">1</Set>
            </If>
            <If Value1="@TextureRefresh" Operator="#_if_eq_" Value2="1">
                <Set Variable="TexMpp">2000</Set>
            </If>

            <!-- ========== TEXTURE REFRESH ========== -->
            <Button Type="#_button_toggle_" X="60" Y="806" Width="90" Height="22"
                Variable="TextureRefresh" On="1" Off="0"
                LocalAlignX="#_align_center_" LocalAlignY="#_align_middle_">
                <ButtonIndicatorOn>
                    <Rectangle FillColor="0.2 0.5 0.2" LineColor="0.3 0.8 0.3" LineWidth="2"/>
                    <Text ParentAlignX="#_align_center_" ParentAlignY="#_align_middle_"
                        LocalAlignX="#_align_center_" LocalAlignY="#_align_middle_"
                        Size="11" FillColor="#_color_white_">Refresh</Text>
                </ButtonIndicatorOn>
                <ButtonIndicatorOff>
                    <Rectangle FillColor="0.15 0.15 0.15" LineColor="0.35 0.35 0.35" LineWidth="1"/>
                    <Text ParentAlignX="#_align_center_" ParentAlignY="#_align_middle_"
                        LocalAlignX="#_align_center_" LocalAlignY="#_align_middle_"
                        Size="11" FillColor="0.6 0.6 0.6">Refresh</Text>
                </ButtonIndicatorOff>
            </Button>

            <!-- ========== ORTHO TOGGLE ========== -->
            <Button Type="#_button_toggle_" X="170" Y="806" Width="90" Height="22"
                Variable="UseOrtho" On="1" Off="0"
                LocalAlignX="#_align_center_" LocalAlignY="#_align_middle_">
                <ButtonIndicatorOn>
                    <Rectangle FillColor="0.2 0.5 0.2" LineColor="0.3 0.8 0.3" LineWidth="2"/>
                    <Text ParentAlignX="#_align_center_" ParentAlignY="#_align_middle_"
                        LocalAlignX="#_align_center_" LocalAlignY="#_align_middle_"
                        Size="11" FillColor="#_color_white_">Ortho</Text>
                </ButtonIndicatorOn>
                <ButtonIndicatorOff>
                    <Rectangle FillColor="0.15 0.15 0.15" LineColor="0.35 0.35 0.35" LineWidth="1"/>
                    <Text ParentAlignX="#_align_center_" ParentAlignY="#_align_middle_"
                        LocalAlignX="#_align_center_" LocalAlignY="#_align_middle_"
                        Size="11" FillColor="0.6 0.6 0.6">Ortho</Text>
                </ButtonIndicatorOff>
            </Button>

            <!-- ========== PER-VIEW SHADER TOGGLES ========== -->
            <Text X="290" Y="806" LocalAlignX="#_align_right_" LocalAlignY="#_align_middle_"
                Size="13" FillColor="#_color_white_">Shaders:</Text>

            <Button Type="#_button_toggle_" X="410" Y="806" Width="150" Height="22"
                Variable="LeftShader" On="2" Off="1" IndicatorOn="2"
                LocalAlignX="#_align_center_" LocalAlignY="#_align_middle_">
                <ButtonIndicatorOn>
                    <Rectangle FillColor="0.45 0.18 0.16" LineColor="0.90 0.30 0.24" LineWidth="2"/>
                    <Text ParentAlignX="#_align_center_" ParentAlignY="#_align_middle_"
                        LocalAlignX="#_align_center_" LocalAlignY="#_align_middle_"
                        Size="11" FillColor="#_color_white_">Left: Slope</Text>
                </ButtonIndicatorOn>
                <ButtonIndicatorOff>
                    <Rectangle FillColor="0.24 0.34 0.14" LineColor="0.70 0.82 0.28" LineWidth="2"/>
                    <Text ParentAlignX="#_align_center_" ParentAlignY="#_align_middle_"
                        LocalAlignX="#_align_center_" LocalAlignY="#_align_middle_"
                        Size="11" FillColor="#_color_white_">Left: Elevation</Text>
                </ButtonIndicatorOff>
            </Button>

            <Button Type="#_button_toggle_" X="590" Y="806" Width="150" Height="22"
                Variable="RightShader" On="1" Off="2" IndicatorOn="1"
                LocalAlignX="#_align_center_" LocalAlignY="#_align_middle_">
                <ButtonIndicatorOn>
                    <Rectangle FillColor="0.24 0.34 0.14" LineColor="0.70 0.82 0.28" LineWidth="2"/>
                    <Text ParentAlignX="#_align_center_" ParentAlignY="#_align_middle_"
                        LocalAlignX="#_align_center_" LocalAlignY="#_align_middle_"
                        Size="11" FillColor="#_color_white_">Right: Elevation</Text>
                </ButtonIndicatorOn>
                <ButtonIndicatorOff>
                    <Rectangle FillColor="0.45 0.18 0.16" LineColor="0.90 0.30 0.24" LineWidth="2"/>
                    <Text ParentAlignX="#_align_center_" ParentAlignY="#_align_middle_"
                        LocalAlignX="#_align_center_" LocalAlignY="#_align_middle_"
                        Size="11" FillColor="#_color_white_">Right: Slope</Text>
                </ButtonIndicatorOff>
            </Button>

            <!-- ========== PLANET VIEWS ========== -->
            <Text X="240" Y="762" LocalAlignX="#_align_center_" Size="14" FillColor="#_color_yellow_">Geodetic Camera</Text>
            <PlanetView Planet="Moon" CRS="#_planet_crs_geodetic_" AttitudeFrame="#_planet_attitude_frame_local_ned_" X="15" Y="300" Width="450" Height="450"
                CameraLatitude="@Latitude" CameraLongitude="@Longitude" CameraElevation="@Elevation"
                CameraYaw="@Heading"
                CameraOrthographic="@UseOrtho" ShaderIndex="@ActiveShader"
                Tau="@Tau">
                <PlanetSphere Latitude="-58.62" Longitude="-14.73" Radius="115385" HeightAboveTerrain="1000" FillColor="0.0 1.0 1.0 0.18"/>
                <PlanetSphere Latitude="-89.67" Longitude="129.78" Radius="10460" HeightAboveTerrain="1000" FillColor="1.0 0.4 1.0 0.22"/>
                <PlanetGeoJSON File="assets/geojson_test.geojson" HeightAboveTerrain="1000" LineColor="1.0 1.0 0.0 1.0" LineWidth="2000" FillColor="1.0 1.0 0.0 0.2"/>
                <PlanetText Latitude="-58.62" Longitude="-14.73" HeightAboveTerrain="50000" Size="60000" FillColor="0.0 1.0 1.0 1.0">Clavius crater 230.77 km</PlanetText>
                <PlanetText Latitude="-89.67" Longitude="129.78" HeightAboveTerrain="50000" Size="30000" FillColor="1.0 0.4 1.0 1.0">Shackleton crater 20.92 km</PlanetText>
            </PlanetView>

            <Text X="760" Y="762" LocalAlignX="#_align_center_" Size="14" FillColor="#_color_sky_blue_">Geodetic Camera (logic)</Text>
            <Container X="535" Y="300" Width="450" Height="450" VirtualWidth="450" VirtualHeight="450">
                <DrawFunction Name="draw_logic_planet_view"/>
            </Container>

            <!-- ========== SLIDERS (below planets) ========== -->

            <!-- Latitude: 0-100 → -90 to +90 deg -->
            <Text X="15" Y="270" LocalAlignX="#_align_left_">Lat:</Text>
            <Text X="195" Y="270" LocalAlignX="#_align_right_">@Latitude(%.1f) deg</Text>
            <Container X="210" Y="260" Width="775" Height="20" VirtualWidth="100">
                <Rectangle FillColor="#_color_dark_gray_" LineColor="#_color_gray_" LineWidth="1"/>
                <If Value1="@SliderLatSelected" Operator="#_if_eq_" Value2="1">
                    <MouseMotion VariableX="SliderLat"/>
                </If>
                <Set Variable="SliderLat" Operator="#_set_max_">0</Set>
                <Set Variable="SliderLat" Operator="#_set_min_">100</Set>
                <Button Type="#_button_momentary_" X="@SliderLat" Y="10" Width="8" Height="26" Variable="SliderLatSelected" LocalAlignX="#_align_center_" LocalAlignY="#_align_middle_">
                    <ButtonIndicatorOn><Rectangle FillColor="#_color_lime_"/></ButtonIndicatorOn>
                    <ButtonIndicatorOff><Rectangle FillColor="#_color_gray_"/></ButtonIndicatorOff>
                </Button>
            </Container>

            <!-- Longitude: 0-100 → 0 to 360 deg -->
            <Text X="15" Y="220" LocalAlignX="#_align_left_">Lon:</Text>
            <Text X="195" Y="220" LocalAlignX="#_align_right_">@Longitude(%.1f) deg</Text>
            <Container X="210" Y="210" Width="775" Height="20" VirtualWidth="100">
                <Rectangle FillColor="#_color_dark_gray_" LineColor="#_color_gray_" LineWidth="1"/>
                <If Value1="@SliderLonSelected" Operator="#_if_eq_" Value2="1">
                    <MouseMotion VariableX="SliderLon"/>
                </If>
                <Set Variable="SliderLon" Operator="#_set_max_">0</Set>
                <Set Variable="SliderLon" Operator="#_set_min_">100</Set>
                <Button Type="#_button_momentary_" X="@SliderLon" Y="10" Width="8" Height="26" Variable="SliderLonSelected" LocalAlignX="#_align_center_" LocalAlignY="#_align_middle_">
                    <ButtonIndicatorOn><Rectangle FillColor="#_color_lime_"/></ButtonIndicatorOn>
                    <ButtonIndicatorOff><Rectangle FillColor="#_color_gray_"/></ButtonIndicatorOff>
                </Button>
            </Container>

            <!-- Elevation: 1-100 → 50,000 to 5,000,000 m -->
            <Text X="15" Y="170" LocalAlignX="#_align_left_">Ele:</Text>
            <Text X="195" Y="170" LocalAlignX="#_align_right_">@Elevation(%.0f) m</Text>
            <Container X="210" Y="160" Width="775" Height="20" VirtualWidth="100">
                <Rectangle FillColor="#_color_dark_gray_" LineColor="#_color_gray_" LineWidth="1"/>
                <If Value1="@SliderEleSelected" Operator="#_if_eq_" Value2="1">
                    <MouseMotion VariableX="SliderEle"/>
                </If>
                <Set Variable="SliderEle" Operator="#_set_max_">1</Set>
                <Set Variable="SliderEle" Operator="#_set_min_">100</Set>
                <Button Type="#_button_momentary_" X="@SliderEle" Y="10" Width="8" Height="26" Variable="SliderEleSelected" LocalAlignX="#_align_center_" LocalAlignY="#_align_middle_">
                    <ButtonIndicatorOn><Rectangle FillColor="#_color_lime_"/></ButtonIndicatorOn>
                    <ButtonIndicatorOff><Rectangle FillColor="#_color_gray_"/></ButtonIndicatorOff>
                </Button>
            </Container>

            <!-- Heading: 0-100 → 0 to 360 deg -->
            <Text X="15" Y="120" LocalAlignX="#_align_left_">Hdg:</Text>
            <Text X="195" Y="120" LocalAlignX="#_align_right_">@Heading(%.0f) deg</Text>
            <Container X="210" Y="110" Width="775" Height="20" VirtualWidth="100">
                <Rectangle FillColor="#_color_dark_gray_" LineColor="#_color_gray_" LineWidth="1"/>
                <If Value1="@SliderHdgSelected" Operator="#_if_eq_" Value2="1">
                    <MouseMotion VariableX="SliderHdg"/>
                </If>
                <Set Variable="SliderHdg" Operator="#_set_max_">0</Set>
                <Set Variable="SliderHdg" Operator="#_set_min_">100</Set>
                <Button Type="#_button_momentary_" X="@SliderHdg" Y="10" Width="8" Height="26" Variable="SliderHdgSelected" LocalAlignX="#_align_center_" LocalAlignY="#_align_middle_">
                    <ButtonIndicatorOn><Rectangle FillColor="#_color_lime_"/></ButtonIndicatorOn>
                    <ButtonIndicatorOff><Rectangle FillColor="#_color_gray_"/></ButtonIndicatorOff>
                </Button>
            </Container>

            <!-- Tau: 1-100 → 0.01 to 1.00 -->
            <Text X="15" Y="70" LocalAlignX="#_align_left_">Tau:</Text>
            <Text X="195" Y="70" LocalAlignX="#_align_right_">@Tau(%.2f)</Text>
            <Container X="210" Y="60" Width="775" Height="20" VirtualWidth="100">
                <Rectangle FillColor="#_color_dark_gray_" LineColor="#_color_gray_" LineWidth="1"/>
                <If Value1="@SliderTauSelected" Operator="#_if_eq_" Value2="1">
                    <MouseMotion VariableX="SliderTau"/>
                </If>
                <Set Variable="SliderTau" Operator="#_set_max_">1</Set>
                <Set Variable="SliderTau" Operator="#_set_min_">100</Set>
                <Button Type="#_button_momentary_" X="@SliderTau" Y="10" Width="8" Height="26" Variable="SliderTauSelected" LocalAlignX="#_align_center_" LocalAlignY="#_align_middle_">
                    <ButtonIndicatorOn><Rectangle FillColor="#_color_lime_"/></ButtonIndicatorOn>
                    <ButtonIndicatorOff><Rectangle FillColor="#_color_gray_"/></ButtonIndicatorOff>
                </Button>
            </Container>

            <!-- Light Y: 0-100 → -1.0 to +1.0 -->
            <Text X="15" Y="20" LocalAlignX="#_align_left_">Light Y:</Text>
            <Text X="195" Y="20" LocalAlignX="#_align_right_">@LightY(%.2f)</Text>
            <Container X="210" Y="10" Width="775" Height="20" VirtualWidth="100">
                <Rectangle FillColor="#_color_dark_gray_" LineColor="#_color_gray_" LineWidth="1"/>
                <If Value1="@SliderLightYSelected" Operator="#_if_eq_" Value2="1">
                    <MouseMotion VariableX="SliderLightY"/>
                </If>
                <Set Variable="SliderLightY" Operator="#_set_max_">0</Set>
                <Set Variable="SliderLightY" Operator="#_set_min_">100</Set>
                <Button Type="#_button_momentary_" X="@SliderLightY" Y="10" Width="8" Height="26" Variable="SliderLightYSelected" LocalAlignX="#_align_center_" LocalAlignY="#_align_middle_">
                    <ButtonIndicatorOn><Rectangle FillColor="#_color_lime_"/></ButtonIndicatorOn>
                    <ButtonIndicatorOff><Rectangle FillColor="#_color_gray_"/></ButtonIndicatorOff>
                </Button>
            </Container>

            <!-- Logic view readout -->
            <Text X="15" Y="290" LocalAlignX="#_align_left_" Size="11" FillColor="#_color_sky_blue_">@LogicReadout</Text>

        </Panel>
    </Window>
</DCAPP>
