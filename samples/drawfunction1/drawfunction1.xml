<?xml version="1.0"?>
<DCAPP>
    <!--
        This sample demonstrates the hybrid pattern:
        - XML handles stable layout, labels, and text.
        - DrawFunction injects C drawing where code is clearer than XML.
    -->
    <Variable Type="#_variable_double_" InitialValue="0">PHASE</Variable>

    <Logic File="logic/logic.so"/>

    <Window Title="DrawFunction 1 - Hybrid Overview" X="30" Y="30" Width="1000" Height="700" VirtualWidth="900" VirtualHeight="600" FrameRateLimit="60">
        <Panel VirtualWidth="900" VirtualHeight="600" BackgroundColor="0.055 0.062 0.070 1">
            <Text X="44" Y="552" Size="28" FillColor="0.88 0.95 1 1">DrawFunction 1: Hybrid Overview</Text>
            <Text X="44" Y="522" Size="14" FillColor="0.50 0.62 0.72 1">Four small examples: primitive draw, logic text, mouse hits, and reusable areas.</Text>

            <Container X="44" Y="300" Width="392" Height="200" VirtualWidth="392" VirtualHeight="200">
                <Rectangle Width="392" Height="200" Rounded="8" FillColor="0.10 0.13 0.16 1" LineColor="0.30 0.42 0.54 1" LineWidth="1"/>
                <Text X="20" Y="166" Size="16" FillColor="0.82 0.93 1 1">1. Primitive draw</Text>
                <Text X="20" Y="144" Size="10" FillColor="0.48 0.58 0.66 1">C draws one circle using placement and stroke.</Text>
                <DrawFunction Name="draw_simple_circle">
                    <Arg Type="#_variable_double_" Value="@PHASE"/>
                </DrawFunction>
            </Container>

            <Container X="464" Y="300" Width="392" Height="200" VirtualWidth="392" VirtualHeight="200">
                <Rectangle Width="392" Height="200" Rounded="8" FillColor="0.13 0.11 0.14 1" LineColor="0.54 0.38 0.58 1" LineWidth="1"/>
                <Text X="20" Y="166" Size="16" FillColor="0.96 0.88 1 1">2. Logic text inside C draw</Text>
                <Text X="20" Y="144" Size="10" FillColor="0.60 0.52 0.66 1">C draws the circle, pushes its area, then centers the text.</Text>
                <DrawFunction Name="draw_labeled_circle">
                    <Arg Type="#_variable_double_" Value="@PHASE"/>
                </DrawFunction>
            </Container>

            <Container X="44" Y="64" Width="392" Height="200" VirtualWidth="392" VirtualHeight="200">
                <Rectangle Width="392" Height="200" Rounded="8" FillColor="0.11 0.14 0.11 1" LineColor="0.36 0.56 0.40 1" LineWidth="1"/>
                <Text X="20" Y="166" Size="16" FillColor="0.88 1 0.90 1">3. Mouse events</Text>
                <Text X="20" Y="144" Size="10" FillColor="0.52 0.66 0.56 1">C registers the circle as a hit target and reacts to hover/click.</Text>
                <DrawFunction Name="draw_mouse_circle">
                    <Arg Type="#_variable_double_" Value="@PHASE"/>
                </DrawFunction>
                <Text X="196" Y="28" Size="10" FillColor="0.62 0.74 0.64 1" LocalAlignX="#_align_center_">Hover or click the circle.</Text>
            </Container>

            <Container X="464" Y="64" Width="392" Height="200" VirtualWidth="392" VirtualHeight="200">
                <Rectangle Width="392" Height="200" Rounded="8" FillColor="0.075 0.085 0.095 1" LineColor="0.26 0.32 0.38 1" LineWidth="1"/>
                <Text X="20" Y="166" Size="16" FillColor="0.82 0.93 1 1">4. Alignment from a drawn area</Text>
                <Text X="20" Y="144" Size="10" FillColor="0.58 0.66 0.72 1">A circle returns an area; C pushes it and aligns children inside.</Text>
                <DrawFunction Name="draw_aligned_area">
                    <Arg Type="#_variable_double_" Value="@PHASE"/>
                </DrawFunction>
            </Container>
        </Panel>
    </Window>
</DCAPP>
