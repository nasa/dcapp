<?xml version="1.0"?>
<DCAPP>
    <Variable Type="#_variable_integer_" InitialValue="50">xPos</Variable>

    <Window X="30" Y="30" Width="800" Height="600">
        <Panel VirtualWidth="800" VirtualHeight="600" BackgroundColor="0.1 0.1 0.18">

            <!-- Title -->
            <Text X="400" Y="560" LocalAlignX="#_align_center_" Size="28" FillColor="1 1 1">Push / Pop / Negate Demo</Text>
            <Text X="400" Y="530" LocalAlignX="#_align_center_" Size="14" FillColor="0.5 0.5 0.5">Each level pushes xPos, adds 100, draws, then pops to restore</Text>

            <!-- ========== FORWARD PASS ========== -->
            <Text X="50" Y="480" Size="16" FillColor="0.7 0.7 0.7">Forward: Push -> Add -> Draw</Text>

            <!-- Level 0: red at x=50 -->
            <Rectangle X="@xPos" Y="440" Width="60" Height="60" LocalAlignX="#_align_center_" LocalAlignY="#_align_middle_"
                FillColor="0.9 0.22 0.27"/>
            <Text X="@xPos" Y="395" LocalAlignX="#_align_center_" Size="12" FillColor="0.9 0.22 0.27">x=@xPos</Text>

            <!-- Push, add 100, draw orange at x=150 -->
            <Set Variable="xPos" Operator="#_set_push_"/>
            <Set Variable="xPos" Operator="#_set_add_">100</Set>
            <Rectangle X="@xPos" Y="440" Width="60" Height="60" LocalAlignX="#_align_center_" LocalAlignY="#_align_middle_"
                FillColor="0.96 0.64 0.38"/>
            <Text X="@xPos" Y="395" LocalAlignX="#_align_center_" Size="12" FillColor="0.96 0.64 0.38">x=@xPos</Text>

            <!-- Push, add 100, draw yellow at x=250 -->
            <Set Variable="xPos" Operator="#_set_push_"/>
            <Set Variable="xPos" Operator="#_set_add_">100</Set>
            <Rectangle X="@xPos" Y="440" Width="60" Height="60" LocalAlignX="#_align_center_" LocalAlignY="#_align_middle_"
                FillColor="0.91 0.77 0.42"/>
            <Text X="@xPos" Y="395" LocalAlignX="#_align_center_" Size="12" FillColor="0.91 0.77 0.42">x=@xPos</Text>

            <!-- Push, add 100, draw green at x=350 -->
            <Set Variable="xPos" Operator="#_set_push_"/>
            <Set Variable="xPos" Operator="#_set_add_">100</Set>
            <Rectangle X="@xPos" Y="440" Width="60" Height="60" LocalAlignX="#_align_center_" LocalAlignY="#_align_middle_"
                FillColor="0.16 0.62 0.56"/>
            <Text X="@xPos" Y="395" LocalAlignX="#_align_center_" Size="12" FillColor="0.16 0.62 0.56">x=@xPos</Text>

            <!-- Push, add 100, draw blue at x=450 -->
            <Set Variable="xPos" Operator="#_set_push_"/>
            <Set Variable="xPos" Operator="#_set_add_">100</Set>
            <Rectangle X="@xPos" Y="440" Width="60" Height="60" LocalAlignX="#_align_center_" LocalAlignY="#_align_middle_"
                FillColor="0.3 0.5 0.8"/>
            <Text X="@xPos" Y="395" LocalAlignX="#_align_center_" Size="12" FillColor="0.3 0.5 0.8">x=@xPos</Text>

            <!-- Arrow -->
            <Text X="560" Y="440" Size="20" FillColor="1 1 1">-></Text>
            <Text X="620" Y="440" Size="14" FillColor="0.7 0.7 0.7">pop back...</Text>

            <!-- ========== REVERSE PASS ========== -->
            <Text X="50" Y="330" Size="16" FillColor="0.7 0.7 0.7">Reverse: Pop -> Draw (restored values)</Text>

            <!-- Pop to green x=350 -->
            <Set Variable="xPos" Operator="#_set_pop_"/>
            <Rectangle X="@xPos" Y="280" Width="60" Height="60" LocalAlignX="#_align_center_" LocalAlignY="#_align_middle_"
                FillColor="0.16 0.62 0.56" Opacity="0.7"/>
            <Text X="@xPos" Y="235" LocalAlignX="#_align_center_" Size="10" FillColor="0.16 0.62 0.56">pop->@xPos</Text>

            <!-- Pop to yellow x=250 -->
            <Set Variable="xPos" Operator="#_set_pop_"/>
            <Rectangle X="@xPos" Y="280" Width="60" Height="60" LocalAlignX="#_align_center_" LocalAlignY="#_align_middle_"
                FillColor="0.91 0.77 0.42" Opacity="0.7"/>
            <Text X="@xPos" Y="235" LocalAlignX="#_align_center_" Size="10" FillColor="0.91 0.77 0.42">pop->@xPos</Text>

            <!-- Pop to orange x=150 -->
            <Set Variable="xPos" Operator="#_set_pop_"/>
            <Rectangle X="@xPos" Y="280" Width="60" Height="60" LocalAlignX="#_align_center_" LocalAlignY="#_align_middle_"
                FillColor="0.96 0.64 0.38" Opacity="0.7"/>
            <Text X="@xPos" Y="235" LocalAlignX="#_align_center_" Size="10" FillColor="0.96 0.64 0.38">pop->@xPos</Text>

            <!-- Pop to red x=50 -->
            <Set Variable="xPos" Operator="#_set_pop_"/>
            <Rectangle X="@xPos" Y="280" Width="60" Height="60" LocalAlignX="#_align_center_" LocalAlignY="#_align_middle_"
                FillColor="0.9 0.22 0.27" Opacity="0.7"/>
            <Text X="@xPos" Y="235" LocalAlignX="#_align_center_" Size="10" FillColor="0.9 0.22 0.27">pop->@xPos</Text>

            <!-- Divider -->
            <Rectangle X="50" Y="190" Width="700" Height="2" FillColor="0.3 0.3 0.4"/>

            <!-- ========== NEGATE DEMO ========== -->
            <Text X="400" Y="160" LocalAlignX="#_align_center_" Size="20" FillColor="1 1 1">Negate Demo</Text>

            <!-- Reset xPos for negate demo -->
            <Set Variable="xPos" Operator="#_set_equal_">150</Set>

            <!-- Original purple -->
            <Rectangle X="150" Y="80" Width="70" Height="70" LocalAlignX="#_align_center_" LocalAlignY="#_align_middle_"
                FillColor="0.61 0.37 0.9"/>
            <Text X="150" Y="30" LocalAlignX="#_align_center_" Size="14" FillColor="0.61 0.37 0.9">x = @xPos</Text>
            <Text X="150" Y="125" LocalAlignX="#_align_center_" Size="10" FillColor="0.8 0.8 0.8">original</Text>

            <Text X="230" Y="80" LocalAlignX="#_align_center_" LocalAlignY="#_align_middle_" Size="24" FillColor="1 1 1">-></Text>

            <!-- Push, negate -->
            <Set Variable="xPos" Operator="#_set_push_"/>
            <Set Variable="xPos" Operator="#_set_negate_"/>

            <!-- Negated pink -->
            <Rectangle X="310" Y="80" Width="70" Height="70" LocalAlignX="#_align_center_" LocalAlignY="#_align_middle_"
                FillColor="0.95 0.36 0.71"/>
            <Text X="310" Y="30" LocalAlignX="#_align_center_" Size="14" FillColor="0.95 0.36 0.71">x = @xPos</Text>
            <Text X="310" Y="125" LocalAlignX="#_align_center_" Size="10" FillColor="0.8 0.8 0.8">negated</Text>

            <Text X="390" Y="80" LocalAlignX="#_align_center_" LocalAlignY="#_align_middle_" Size="24" FillColor="1 1 1">-></Text>

            <!-- Pop to restore -->
            <Set Variable="xPos" Operator="#_set_pop_"/>

            <!-- Restored cyan -->
            <Rectangle X="470" Y="80" Width="70" Height="70" LocalAlignX="#_align_center_" LocalAlignY="#_align_middle_"
                FillColor="0 0.96 0.83"/>
            <Text X="470" Y="30" LocalAlignX="#_align_center_" Size="14" FillColor="0 0.96 0.83">x = @xPos</Text>
            <Text X="470" Y="125" LocalAlignX="#_align_center_" Size="10" FillColor="0.8 0.8 0.8">restored!</Text>

        </Panel>
    </Window>
</DCAPP>
