<?xml version="1.0"?>
<DCAPP>
    <Constant Name="PanelWidth">800</Constant>
    <Constant Name="PanelHeight">600</Constant>
    <Constant Name="SphereRadius">300</Constant>
    <Constant Name="SpinRate">45</Constant>

    <Variable Type="#_variable_double_">YAW_ANGLE</Variable>

    <Window X="0" Y="20" Width="800" Height="600">
        <Panel VirtualWidth="#PanelWidth" VirtualHeight="#PanelHeight" BackgroundColor="0.1 0.1 0.2">

            <!-- Spinning NASA sphere in the center -->
            <Sphere
                ParentAlignX="#_align_center_"
                ParentAlignY="#_align_middle_"
                LocalAlignX="#_align_center_"
                LocalAlignY="#_align_middle_"
                Radius="#SphereRadius"
                Image="../../assets/moon.jpg"
                Yaw="@YAW_ANGLE"
            />

            <!-- Increment yaw each frame to spin -->
            <Set Variable="YAW_ANGLE" Operator="#_set_add_">0.5</Set>

            <!-- Title text -->
            <Text
                ParentAlignX="#_align_center_"
                Y="50"
                LocalAlignX="#_align_center_"
                FillColor="1 1 1"
                Size="32"
            >Spinning NASA Sphere</Text>

        </Panel>
    </Window>
</DCAPP>
