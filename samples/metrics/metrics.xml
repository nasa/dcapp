<?xml version="1.0"?>
<DCAPP>

  <Variable Type="#_variable_double_" InitialValue="0">ROTATION</Variable>

  <Window X="30" Y="30" Width="1000" Height="1000" VirtualWidth="1000" VirtualHeight="1000">
    <Panel VirtualWidth="1000" VirtualHeight="1000">

      <Set Variable="ROTATION" Operator="#_set_add_">2</Set>
      <If Value1="@ROTATION" Operation="#_if_gt_" Value2="360">
        <Set Variable="ROTATION" Operator="#_set_equal_">0</Set>
      </If>

      <Include>triangles.xml</Include>
      <Include>include.xml</Include>

    </Panel>
  </Window>
</DCAPP>
