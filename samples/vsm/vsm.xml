<?xml version="1.0"?>
<DCAPP>
    <Constant Name="CamID1">CM_Cam</Constant>
    <Constant Name="CamID2">BASE</Constant>
    <Constant Name="CamID3">MBS_CAMERA</Constant>

    <Variable Type="#_variable_string_" InitialValue="#CamID1">Camera1</Variable>
    <Variable Type="#_variable_string_" InitialValue="#CamID1">Camera2</Variable>
    <Variable Type="#_variable_string_" InitialValue="#CamID1">Camera3</Variable>
    <Variable Type="#_variable_string_" InitialValue="#CamID1">Camera4</Variable>

    <Default>
        <Text ForceMono="Numeric" ParentAlignX="#_align_center_" ParentAlignY="#_align_middle_" LocalAlignX="#_align_center_" LocalAlignY="#_align_middle_" Size="14" FillColor="1 1 1"/>
        <Button Width="100" Height="20" ParentAlignX="#_align_bottom_" ParentAlignY="#_align_left_" LocalAlignX="#_align_bottom_" LocalAlignY="#_align_left_"/>
        <Rectangle LineColor="1 1 1"/>
        <Container Width="400" Height="300"/>
    </Default>

    <Window X="50" Y="50" Width="800" Height="600">
        <Panel VirtualWidth="800" VirtualHeight="600" BackgroundColor="0 0 0">
            <Container X="0" Y="300">
                <Constant Name="MyCamera">@Camera1</Constant>
                <Include>view.xml</Include>
            </Container>

            <Container X="400" Y="300">
                <Constant Name="MyCamera">@Camera2</Constant>
                <Include>view.xml</Include>
            </Container>
            <Container X="0" Y="0">
                <Constant Name="MyCamera">@Camera3</Constant>
                <Include>view.xml</Include>
            </Container>
            <Container X="400" Y="0">
                <Constant Name="MyCamera">@Camera4</Constant>
                <Include>view.xml</Include>
            </Container>

            <Line LineWidth="2" LineColor="0.5 0.5 0.5">
                <Vertex X="400" Y="0"/>
                <Vertex X="400" Y="600"/>
            </Line>
            <Line LineWidth="2" LineColor="0.5 0.5 0.5">
                <Vertex X="0" Y="300"/>
                <Vertex X="800" Y="300"/>
            </Line>
        </Panel>
    </Window>
</DCAPP>
