<?xml version="1.0"?>
<DCAPP>
    <Variable Type="#_variable_double_" InitialValue="0.5">RED</Variable>
    <Variable Type="#_variable_double_" InitialValue="0.5">GREEN</Variable>
    <Variable Type="#_variable_double_" InitialValue="0.5">BLUE</Variable>
    <Variable Type="#_variable_double_" InitialValue="0.5">ALPHA</Variable>

    <Window X="30" Y="30" Width="800" Height="600">
        <Constant Name="BgColor">0 0 0</Constant>
        <Constant Name="FgColor">1 1 1</Constant>

        <Default>
            <Button Y="7.5" Width="10" Height="10" ParentAlignX="#_align_center_" LocalAlignX="#_align_center_" LocalAlignY="#_align_middle_"/>
            <Text Size="3" FillColor="0 0 0" ParentAlignX="#_align_center_" ParentAlignY="#_align_middle_" LocalAlignX="#_align_center_" LocalAlignY="#_align_middle_"/>
        </Default>

        <Style Name="Button">
            <Text Size="2.5" FillColor="1 1 1" ShadowOffset=".2"/>
        </Style>

        <Panel VirtualWidth="100" VirtualHeight="100" BackgroundColor="#BgColor">
            <Text X="20" Y="92.5" FillColor="1 1 1">R: @RED(%.2f)</Text>
            <Text X="40" Y="92.5" FillColor="1 1 1">G: @GREEN(%.2f)</Text>
            <Text X="60" Y="92.5" FillColor="1 1 1">B: @BLUE(%.2f)</Text>
            <Text X="80" Y="92.5" FillColor="1 1 1">A: @ALPHA(%.2f)</Text>
            <Image Width="46" Height="50" ParentAlignX="#_align_center_" ParentAlignY="#_align_middle_" LocalAlignX="#_align_center_" LocalAlignY="#_align_middle_" File="../../assets/nasa.png"/>
            <Rectangle Width="70" Height="70" ParentAlignX="#_align_center_" ParentAlignY="#_align_middle_" LocalAlignX="#_align_center_" LocalAlignY="#_align_middle_" FillColor="@RED @GREEN @BLUE @ALPHA" LineColor="1 1 1"/>
            <Button Type="#_button_momentary_" X="7">
                <MousePressed><Set Variable="RED" Operator="#_set_subtract_" MinimumValue="0">.05</Set></MousePressed>
                <ButtonIndicatorOn><Image File="../../assets/button_on.png"/></ButtonIndicatorOn>
                <ButtonIndicatorOff><Image File="../../assets/button_off.png"/></ButtonIndicatorOff>
                <Text Style="Button">Red\n-</Text>
            </Button>
            <Button Type="#_button_momentary_" X="18">
                <MousePressed><Set Variable="RED" Operator="#_set_add_" MaximumValue="1">.05</Set></MousePressed>
                <ButtonIndicatorOn><Image File="../../assets/button_on.png"/></ButtonIndicatorOn>
                <ButtonIndicatorOff><Image File="../../assets/button_off.png"/></ButtonIndicatorOff>
                <Text Style="Button">Red\n+</Text>
            </Button>
            <Button Type="#_button_momentary_" X="32">
                <MousePressed><Set Variable="GREEN" Operator="#_set_subtract_" MinimumValue="0">.05</Set></MousePressed>
                <ButtonIndicatorOn><Image File="../../assets/button_on.png"/></ButtonIndicatorOn>
                <ButtonIndicatorOff><Image File="../../assets/button_off.png"/></ButtonIndicatorOff>
                <Text Style="Button">Green\n-</Text>
            </Button>
            <Button Type="#_button_momentary_" X="43">
                <MousePressed><Set Variable="GREEN" Operator="#_set_add_" MaximumValue="1">.05</Set></MousePressed>
                <ButtonIndicatorOn><Image File="../../assets/button_on.png"/></ButtonIndicatorOn>
                <ButtonIndicatorOff><Image File="../../assets/button_off.png"/></ButtonIndicatorOff>
                <Text Style="Button">Green\n+</Text>
            </Button>
            <Button Type="#_button_momentary_" X="57">
                <MousePressed><Set Variable="BLUE" Operator="#_set_subtract_" MinimumValue="0">.05</Set></MousePressed>
                <ButtonIndicatorOn><Image File="../../assets/button_on.png"/></ButtonIndicatorOn>
                <ButtonIndicatorOff><Image File="../../assets/button_off.png"/></ButtonIndicatorOff>
                <Text Style="Button">Blue\n-</Text>
            </Button>
            <Button Type="#_button_momentary_" X="68">
                <MousePressed><Set Variable="BLUE" Operator="#_set_add_" MaximumValue="1">.05</Set></MousePressed>
                <ButtonIndicatorOn><Image File="../../assets/button_on.png"/></ButtonIndicatorOn>
                <ButtonIndicatorOff><Image File="../../assets/button_off.png"/></ButtonIndicatorOff>
                <Text Style="Button">Blue\n+</Text>
            </Button>
            <Button Type="#_button_momentary_" X="82">
                <MousePressed><Set Variable="ALPHA" Operator="#_set_subtract_" MinimumValue="0">.05</Set></MousePressed>
                <ButtonIndicatorOn><Image File="../../assets/button_on.png"/></ButtonIndicatorOn>
                <ButtonIndicatorOff><Image File="../../assets/button_off.png"/></ButtonIndicatorOff>
                <Text Style="Button">Alpha\n-</Text>
            </Button>
            <Button Type="#_button_momentary_" X="93">
                <MousePressed><Set Variable="ALPHA" Operator="#_set_add_" MaximumValue="1">.05</Set></MousePressed>
                <ButtonIndicatorOn><Image File="../../assets/button_on.png"/></ButtonIndicatorOn>
                <ButtonIndicatorOff><Image File="../../assets/button_off.png"/></ButtonIndicatorOff>
                <Text Style="Button">Alpha\n+</Text>
            </Button>
        </Panel>
    </Window>
</DCAPP>
