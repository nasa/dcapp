<?xml version="1.0"?>
<DCAPP>
    <Window X="30" Y="30" Width="900" Height="700">
        <Panel VirtualWidth="900" VirtualHeight="700" BackgroundColor="0.06 0.06 0.1">

            <!-- Title -->
            <Text X="450" Y="670" Size="28" FillColor="1 1 1" LocalAlignX="#_align_center_">Line Dash Patterns</Text>

            <!-- ================================================================== -->
            <!-- LINE PATTERNS (upper section) -->
            <!-- ================================================================== -->
            <Text X="450" Y="620" Size="16" FillColor="0.6 0.8 1" LocalAlignX="#_align_center_">Lines</Text>

            <!-- 0xFF = solid (default) -->
            <Text X="50" Y="590" Size="11" FillColor="0.5 0.5 0.5">0xFF solid</Text>
            <Line LineColor="1 0.5 0.3" LineWidth="3" LinePattern="0xFF">
                <Vertex X="200" Y="590"/>
                <Vertex X="850" Y="590"/>
            </Line>

            <!-- 0xFE = long dash, tiny gap (7 on, 1 off) -->
            <Text X="50" Y="560" Size="11" FillColor="0.5 0.5 0.5">0xFE long dash</Text>
            <Line LineColor="0.3 0.8 1" LineWidth="3" LinePattern="0xFE">
                <Vertex X="200" Y="560"/>
                <Vertex X="850" Y="560"/>
            </Line>

            <!-- 0xF8 = dash (5 on, 3 off) -->
            <Text X="50" Y="530" Size="11" FillColor="0.5 0.5 0.5">0xF8 dash</Text>
            <Line LineColor="0.3 1 0.5" LineWidth="3" LinePattern="0xF8">
                <Vertex X="200" Y="530"/>
                <Vertex X="850" Y="530"/>
            </Line>

            <!-- 0xCC = short dash (2 on, 2 off) -->
            <Text X="50" Y="500" Size="11" FillColor="0.5 0.5 0.5">0xCC short dash</Text>
            <Line LineColor="1 1 0.3" LineWidth="3" LinePattern="0xCC">
                <Vertex X="200" Y="500"/>
                <Vertex X="850" Y="500"/>
            </Line>

            <!-- 0xAA = dotted (1 on, 1 off) -->
            <Text X="50" Y="470" Size="11" FillColor="0.5 0.5 0.5">0xAA dotted</Text>
            <Line LineColor="1 0.3 1" LineWidth="3" LinePattern="0xAA">
                <Vertex X="200" Y="470"/>
                <Vertex X="850" Y="470"/>
            </Line>

            <!-- 0xE4 = dash-dot (3 on, 1 off, 1 on, 1 off, 0, 0) -->
            <Text X="50" Y="440" Size="11" FillColor="0.5 0.5 0.5">0xE4 dash-dot</Text>
            <Line LineColor="0.8 0.5 0.2" LineWidth="3" LinePattern="0xE4">
                <Vertex X="200" Y="440"/>
                <Vertex X="850" Y="440"/>
            </Line>

            <!-- ================================================================== -->
            <!-- SHAPE OUTLINES (lower section) -->
            <!-- ================================================================== -->
            <Text X="450" Y="260" Size="16" FillColor="0.6 0.8 1" LocalAlignX="#_align_center_">Shape Outlines</Text>

            <!-- Dashed rectangle -->
            <Text X="150" Y="110" Size="11" FillColor="0.5 0.5 0.5" LocalAlignX="#_align_center_">Rectangle 0xAA</Text>
            <Rectangle X="80" Y="140" Width="140" Height="90" LineColor="1 0.6 0.3" LineWidth="2" LinePattern="0xAA"/>

            <!-- Dashed ellipse -->
            <Text X="380" Y="110" Size="11" FillColor="0.5 0.5 0.5" LocalAlignX="#_align_center_">Ellipse 0xF0</Text>
            <Ellipse X="380" Y="190" RadiusX="70" RadiusY="45" LineColor="0.3 0.9 0.6" LineWidth="2" LinePattern="0xF0"/>

            <!-- Dashed polygon (triangle) -->
            <Text X="600" Y="110" Size="11" FillColor="0.5 0.5 0.5" LocalAlignX="#_align_center_">Polygon 0xCC</Text>
            <Polygon LineColor="0.5 0.5 1" LineWidth="2" LinePattern="0xCC">
                <Vertex X="600" Y="230"/>
                <Vertex X="540" Y="140"/>
                <Vertex X="660" Y="140"/>
                <Vertex X="600" Y="230"/>
            </Polygon>

            <!-- Dashed arc -->
            <Text X="790" Y="110" Size="11" FillColor="0.5 0.5 0.5" LocalAlignX="#_align_center_">Arc 0xE4</Text>
            <Arc X="790" Y="190" Radius="45" Angle="270" LineColor="1 0.4 0.7" LineWidth="3" LinePattern="0xE4"/>

        </Panel>
    </Window>
</DCAPP>
