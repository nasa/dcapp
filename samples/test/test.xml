<?xml version="1.0"?>
<DCAPP>

  <Logic File="logic/logic.so" />
  <Window Title="dcapp-vk-title" X="30" Y="30" Width="1000" Height="1000" VirtualWidth="1000" VirtualHeight="1000">

    <Variable Type="Double" InitialValue="30">ROTATE</Variable>

    <!-- Trick (connected to cannonball sim)-->
    <Variable Type="Float">POS_X</Variable>
    <Variable Type="Float">POS_Y</Variable>
    <Variable Type="Float">VEL_Y</Variable>
    <Variable Type="Float" InitialValue="404">G</Variable>
    <TrickIO Host="localhost" Port="9123">
      <FromTrick>
        <TrickVariable Name="dyn.cannon.pos[0]">POS_X</TrickVariable>
        <TrickVariable Name="dyn.cannon.pos[1]">POS_Y</TrickVariable>
        <TrickVariable Name="dyn.cannon.vel[1]">VEL_Y</TrickVariable>
      </FromTrick>
      <ToTrick>
        <TrickVariable Name="dyn.cannon.g">G</TrickVariable>
      </ToTrick>
    </TrickIO>

    <!-- panel -->
    <Panel VirtualWidth="1000" VirtualHeight="1000">

      <!-- modify some variables -->
      <Set Variable="G" Operator="#_set_add_">.001</Set>
      <Set Variable="ROTATE" Operator="#_set_add_">2</Set>
      <If Value1="@ROTATE" Operation="#_conditional_gt_" Value2="360">
        <Set Variable="ROTATE" Operator="#_set_equal_">1</Set>
      </If>

      <!-- draw -->
      <Polygon FillColor="1 0 0 .5" LineColor="1 1 1" LineWidth="2">
        <Vertex X="100" Y="0" />
        <Vertex X="400" Y="0" />
        <Vertex X="100" Y="300" />
      </Polygon>

      <Container Width="500" Height="500" X="0" Y="0" OriginX="500" OriginY="500" VirtualWidth="1000" VirtualHeight="1000" Rotation="@ROTATE">
        <Polygon FillColor="0 1 0 1" LineColor="1 1 1" LineWidth="1">
          <Vertex X="0" Y="0" />
          <Vertex X="0" Y="-1000" />
          <Vertex X="-1000" Y="-1000" />
          <Vertex X="-1000" Y="0" />
        </Polygon>
      </Container>

      <Container Width="1000" Height="1000" OriginX="500" OriginY="500" X="0" Y="0" VirtualWidth="1000" VirtualHeight="1000" Rotation="@ROTATE">

        <Polygon FillColor="0 1 0 1" LineColor="1 1 1" LineWidth="1">
          <Vertex X="100" Y="100" />
          <Vertex X="200" Y="380" />
          <Vertex X="440" Y="280" />
        </Polygon>

        <Polygon FillColor="0 1 0 1" LineColor="1 1 1" LineWidth="2">
          <Vertex X="25" Y="100" />
          <Vertex X="125" Y="380" />
          <Vertex X="250" Y="280" />
        </Polygon>

        <Polygon FillColor="0 1 0 1" LineColor="1 1 1" LineWidth="20">
          <Vertex X="100" Y="250" />
          <Vertex X="500" Y="400" />
          <Vertex X="600" Y="80" />
          <Vertex X="200" Y="80" />
        </Polygon>

        <Polygon FillColor="1 0 0 .5" LineColor="1 1 1 .5" LineWidth="3">
          <Vertex X="0" Y="250" />
          <Vertex X="-250" Y="-250" />
          <Vertex X="250" Y="-250" />
        </Polygon>

        <Container X="500" Y="500" Width="500" Height="500">
          <Polygon FillColor="0 1 0 1" LineColor="1 1 1" LineWidth="2">
            <Vertex X="25" Y="100" />
            <Vertex X="125" Y="380" />
            <Vertex X="250" Y="280" />
          </Polygon>
        </Container>

      </Container>

      <Polygon FillColor="1 0 0 1" LineColor="1 1 1" LineWidth="2">
        <Vertex X="500" Y="250" />
        <Vertex X="510" Y="250" />
        <Vertex X="510" Y="260" />
        <Vertex X="500" Y="260" />
      </Polygon>

      <Text Size="75" X="500" Y="750" HorizontalAlign="#_align_center_" VerticalAlign="#_align_middle_" PivotAlignX="#_align_right_" PivotAlignY="#_align_top_" Rotation="@ROTATE" FillColor="@ROTATE .5 .5 1">TOP RIGHT</Text>
      <Text Size="75" X="500" Y="500" HorizontalAlign="#_align_center_" VerticalAlign="#_align_middle_" PivotAlignX="#_align_center_" PivotAlignY="#_align_middle_" Rotation="@ROTATE" FillColor="@ROTATE .5 .5 1">CENTER MIDDLE</Text>
      <Text Size="75" X="500" Y="250" HorizontalAlign="#_align_left_" VerticalAlign="#_align_bottom_" PivotAlignX="#_align_left_" PivotAlignY="#_align_bottom_" Rotation="@ROTATE" FillColor="@ROTATE .5 .5 1">BOTTOM LEFT</Text>

    </Panel>

    <!-- <Include>sub/subtest.xml</Include> -->
  </Window>
</DCAPP>