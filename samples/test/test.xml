<?xml version="1.0"?>
<DCAPP>

  <Logic File="logic/logic.so" />
  <Window Title="dcapp-vk-title" X="2000" Y="500" Width="1000" Height="1000" VirtualWidth="1000" VirtualHeight="1000">

    <Constant Name="Constant1">Constant2</Constant>
    <Constant Name="Constant2">30</Constant>

    <Variable Type="Double" InitialValue="#Constant1">ROTATE</Variable>

    <Variable Type="Float" InitialValue="0">COLOR_R</Variable>
    <Variable Type="Float" InitialValue=".25">COLOR_G</Variable>
    <Variable Type="Float" InitialValue=".5">COLOR_B</Variable>

    <!-- Trick (connected to cannonball sim)-->
    <Variable Type="Float">POS_X</Variable>
    <Variable Type="Float">POS_Y</Variable>
    <Variable Type="Float">VEL_Y</Variable>
    <Variable Type="Float" InitialValue="404">G</Variable>
    <TrickIO Host="localhost" Port="9123">
      <FromTrick>
        <TrickVariable Name="dyn.cannon.pos[0]">POS_X</TrickVariable>
        <TrickVariable Name="dyn.cannon.pos[1]">POS_Y</TrickVariable>
        <TrickVariable Name="dyn.cannon.vel[1]">VEL_Y</TrickVariable>
      </FromTrick>
      <ToTrick>
        <TrickVariable Name="dyn.cannon.g">G</TrickVariable>
      </ToTrick>
    </TrickIO>

    <!-- panel -->
    <Panel VirtualWidth="1000" VirtualHeight="1000">

      <Text Size="100" X="500" Y="500" FillColor="#_color_terracotta_" LocalAlignX="#_align_center_" LocalAlignY="#_align_middle_">line1\nlinasdfe2\nline3</Text>

      <Rectangle X="400" Y="400" Width="200" Height="200" FillColor="#_color_champagne_ .3"></Rectangle>

      <Circle HorizontalAlign="#_align_left_" X="0" Y="300" Radius="200" FillColor="#_color_yellow_">
        <MouseActive>
          <Text Size="75" ParentAlignX="#_align_left_" ParentAlignY="#_align_top_" HorizontalAlign="#_align_left_" VerticalAlign="#_align_top_" FillColor="#_color_white_">active!</Text>
        </MouseActive>
      </Circle>

      <!-- modify some variables -->
      <Set Variable="G" Operator="#_set_add_">.001</Set>
      <Set Variable="ROTATE" Operator="#_set_add_">.5</Set>
      <If Value1="@ROTATE" Operation="#_conditional_gt_" Value2="360">
        <Set Variable="ROTATE" Operator="#_set_equal_">0</Set>
      </If>

      <!-- draw -->
      <Polygon FillColor="1 0 0 .5" LineColor="1 1 1" LineWidth="2">
        <Vertex X="100" Y="0" />
        <Vertex X="400" Y="0" />
        <Vertex X="100" Y="300" />
      </Polygon>

      <Container Width="500" Height="500" X="500" Y="500" VirtualWidth="1000" VirtualHeight="1000" Rotation="@ROTATE">
        <Polygon FillColor="#_color_green_ .25" LineColor="1 1 1" LineWidth="1">
          <Vertex X="0" Y="0" />
          <Vertex X="0" Y="-1000" />
          <Vertex X="-1000" Y="-1000" />
          <Vertex X="-1000" Y="0" />
        </Polygon>
        <Line LineColor="#_color_sapphire_ .5" LineWidth="5">
          <Vertex X="0" Y="0" />
          <Vertex X="0" Y="-1000" />
          <Vertex X="-1000" Y="-1000" />
          <Vertex X="-1000" Y="0" />
        </Line>

        <!-- <Image File="/data/nreagan/dcapp/samples/screensaver/images/nasa.tga" X="250" Y="750"/> -->
      </Container>

      <Container Width="1000" Height="1000" X="500" Y="500" VirtualWidth="1000" VirtualHeight="1000" Rotation="@ROTATE">

        <Polygon FillColor="#_color_green_ .25" LineColor="1 1 1" LineWidth="1">
          <Vertex X="100" Y="100" />
          <Vertex X="200" Y="380" />
          <Vertex X="440" Y="280" />
          <MouseInactive>
            <Text Size="75" ParentAlignX="#_align_center_" ParentAlignY="#_align_middle_" HorizontalAlign="#_align_center_" VerticalAlign="#_align_middle_" FillColor="#_color_white_">TEST TEST</Text>
          </MouseInactive>
        </Polygon>

        <Polygon FillColor="#_color_green_ .25" LineColor="1 1 1" LineWidth="2">
          <Vertex X="25" Y="100" />
          <Vertex X="125" Y="380" />
          <Vertex X="250" Y="280" />
        </Polygon>

        <Polygon FillColor="#_color_green_ .25" LineColor="1 1 1" LineWidth="20">
          <Vertex X="100" Y="250" />
          <Vertex X="500" Y="400" />
          <Vertex X="600" Y="80" />
          <Vertex X="200" Y="80" />
        </Polygon>

        <Style Name="MouseTesting">
          <Text Size="75" ParentAlignX="#_align_center_" ParentAlignY="#_align_middle_" HorizontalAlign="#_align_center_" VerticalAlign="#_align_middle_" FillColor="#_color_white_" />
        </Style>
        <Polygon FillColor="#_color_red_ .5" LineColor="1 1 1 .5" LineWidth="3" Rotation="@ROTATE" PivotPositionX="0" PivotPositionY="150">

          <Vertex X="0" Y="250" />
          <Vertex X="-250" Y="-250" />
          <Vertex X="250" Y="-250" />
          <MouseActive>
            <Text Style="MouseTesting">active</Text>
          </MouseActive>
          <MouseHovered>
            <Text Style="MouseTesting">hovered</Text>
          </MouseHovered>
          <MouseInactive>
            <Text Style="MouseTesting">inactive\ntest\ntest2</Text>
          </MouseInactive>
          <MousePressed>
            <Text Style="MouseTesting">pressed</Text>
          </MousePressed>
          <MouseReleased>
            <Text Style="MouseTesting">released</Text>
          </MouseReleased>
        </Polygon>

        <Container X="500" Y="500" Width="500" Height="500">
          <Polygon FillColor="#_color_green_ .25" LineColor="1 1 1" LineWidth="2">
            <Vertex X="25" Y="100" />
            <Vertex X="125" Y="380" />
            <Vertex X="250" Y="280" />
          </Polygon>
        </Container>

      </Container>

      <Set Variable="COLOR_R" Operator="#_set_add_">.01</Set>
      <If Value1="@COLOR_R" Operation="#_conditional_gt_" Value2="1">
        <Set Variable="COLOR_R" Operator="#_set_equal_">0</Set>
      </If>

      <Set Variable="COLOR_G" Operator="#_set_add_">.02</Set>
      <If Value1="@COLOR_G" Operation="#_conditional_gt_" Value2="1">
        <Set Variable="COLOR_G" Operator="#_set_equal_">0</Set>
      </If>

      <Set Variable="COLOR_B" Operator="#_set_add_">.03</Set>
      <If Value1="@COLOR_B" Operation="#_conditional_gt_" Value2="1">
        <Set Variable="COLOR_B" Operator="#_set_equal_">0</Set>
      </If>


      <Polygon FillColor="1 0 0 1" LineColor="1 1 1" LineWidth="2">
        <Vertex X="495" Y="745" />
        <Vertex X="505" Y="745" />
        <Vertex X="505" Y="755" />
        <Vertex X="495" Y="755" />
      </Polygon>
      <Text Size="75" X="500" Y="750" HorizontalAlign="#_align_right_" VerticalAlign="#_align_top_" PivotLocalAlignX="#_align_right_" PivotLocalAlignY="#_align_top_" Rotation="@ROTATE" FillColor="@COLOR_R @COLOR_G @COLOR_B 1">TOP RIGHT</Text>

      <Polygon FillColor="1 0 0 1" LineColor="1 1 1" LineWidth="2">
        <Vertex X="495" Y="495" />
        <Vertex X="505" Y="495" />
        <Vertex X="505" Y="505" />
        <Vertex X="495" Y="505" />
      </Polygon>
      <Text Size="75" X="500" Y="500" HorizontalAlign="#_align_center_" VerticalAlign="#_align_middle_" PivotLocalAlignX="#_align_center_" PivotLocalAlignY="#_align_middle_" Rotation="@ROTATE" FillColor="@COLOR_G @COLOR_B @COLOR_R 1">CENTER MIDDLE</Text>

      <Polygon FillColor="1 0 0 1" LineColor="1 1 1" LineWidth="2">
        <Vertex X="495" Y="245" />
        <Vertex X="505" Y="245" />
        <Vertex X="505" Y="255" />
        <Vertex X="495" Y="255" />
      </Polygon>

      <Style Name="Test Style">
        <Text FillColor="@COLOR_B @COLOR_R @COLOR_G 1" />
      </Style>

      <Text Style="Test Style" Size="75" X="500" Y="250" HorizontalAlign="#_align_left_" VerticalAlign="#_align_bottom_" PivotLocalAlignX="#_align_left_" PivotLocalAlignY="#_align_bottom_" Rotation="@ROTATE">BOTTOM LEFT</Text>

      <Text Size="1000" X="0" Y="0" HorizontalAlign="#_align_left_" VerticalAlign="#_align_bottom_" FillColor="0 0 1 .25">E</Text>

      <Terrain X="100" Y="100" Width="200" Height="200" Latitude="0" Longitude="0" Elevation="0" Roll="0" Pitch="0" Yaw="0">
        <TerrainDEM File="asdf.txt" />
      </Terrain>

      <PixelStream URL="http://61.211.241.239/nphMotionJpeg?Resolution=320x240&amp;Quality=Standard" Type="#_pixelstream_mjpeg_" Width="200" Height="200"/>

    </Panel>

    <!-- <Include>sub/subtest.xml</Include> -->
  </Window>
</DCAPP>