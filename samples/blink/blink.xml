<?xml version="1.0"?>
<DCAPP>
    <Variable Type="#_variable_integer_" InitialValue="0">CIRCLE_START_BLINK</Variable>

    <Window X="30" Y="30" Width="640" Height="480">
        <Constant Name="BgColor">0 0 0</Constant>
        <Constant Name="FgColor">1 1 1</Constant>
        <Default>
            <Text Size="80" FillColor="#FgColor"/>
        </Default>

        <Panel VirtualWidth="1600" VirtualHeight="1200" BackgroundColor="#BgColor">
            <Blink Frequency=".8" DutyCycle=".70" Duration="0" Variable="CIRCLE_START_BLINK">
                <Image X="250" Y="600" Width="600" Height="500" File="../../assets/nasa.png"/>
            </Blink>

            <Blink Frequency="2" DutyCycle=".50" Duration="3" Variable="CIRCLE_START_BLINK">
                <Image X="250" Y="40" Width="600" Height="500" File="../../assets/nasa.png"/>
            </Blink>

            <Button Type="#_button_toggle_" X="1000" Y="500" Width="420" Height="200">
                <MousePressed>
                    <Set Variable="CIRCLE_START_BLINK" Operator="#_set_add_">1</Set>
                </MousePressed>
                <ButtonIndicatorOn>
                    <Rectangle FillColor="0 .5 0"/>
                    <Text ParentAlignX="#_align_center_" ParentAlignY="#_align_middle_" LocalAlignX="#_align_center_" LocalAlignY="#_align_middle_" Size="75">Start</Text>
                </ButtonIndicatorOn>
                <ButtonIndicatorOff>
                    <Rectangle FillColor=".5 0 0"/>
                    <Text ParentAlignX="#_align_center_" ParentAlignY="#_align_middle_" LocalAlignX="#_align_center_" LocalAlignY="#_align_middle_" Size="75">Stop</Text>
                </ButtonIndicatorOff>
            </Button>
        </Panel>
    </Window>
</DCAPP>
