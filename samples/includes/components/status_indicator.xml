<!-- Reusable Status Indicator Component -->
<!-- Parameters: #IndicatorX, #IndicatorY, #IndicatorLabel, @STATUS_VAR -->
<Dummy>
    <Container X="#IndicatorX" Y="#IndicatorY" Width="120" Height="40">
        <Rectangle Width="120" Height="40" FillColor="0.15 0.15 0.2" LineColor="0.3 0.3 0.4" LineWidth="1"/>

        <!-- Status light -->
        <If Value1="@STATUS_VAR" Operator="#_if_eq_" Value2="1">
            <Ellipse X="25" Y="20" Radius="12" FillColor="0.2 0.8 0.3" LineColor="0.3 0.9 0.4" LineWidth="1"/>
        </If>
        <If Value1="@STATUS_VAR" Operator="#_if_eq_" Value2="0">
            <Ellipse X="25" Y="20" Radius="12" FillColor="0.8 0.2 0.2" LineColor="0.9 0.3 0.3" LineWidth="1"/>
        </If>

        <!-- Label -->
        <Text X="70" Y="20" LocalAlignX="#_align_center_" LocalAlignY="#_align_middle_" Size="10" FillColor="0.8 0.8 0.8">#IndicatorLabel</Text>
    </Container>
</Dummy>
