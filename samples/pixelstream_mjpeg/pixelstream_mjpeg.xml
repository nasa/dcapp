<DCAPP>
    <!--
        PixelStream MJPEG Sample

        Displays a live MJPEG video stream from a local test server.

        Usage:
            1. Start the test server:   python3 server.py
            2. Run dcapp:               dcapp pixelstream_mjpeg.xml
    -->

    <Window Title="PixelStream MJPEG Demo" Width="800" Height="600" VirtualWidth="800" VirtualHeight="600">

        <!-- Background -->
        <Rectangle Width="800" Height="600" FillColor="0.06 0.06 0.09"/>

        <!-- Title -->
        <Text ParentAlignX="#_align_center_" Y="570" LocalAlignX="#_align_center_" Size="22" FillColor="0.9 0.9 1">PixelStream MJPEG</Text>
        <Text ParentAlignX="#_align_center_" Y="545" LocalAlignX="#_align_center_" Size="12" FillColor="0.5 0.5 0.6">Live video stream from Python test server</Text>

        <!-- MJPEG Stream -->
        <PixelStream
            Type="#_pixelstream_mjpeg_"
            URL="http://localhost:8090/stream"
            Timeout="5"
            X="80" Y="30"
            Width="640" Height="480"
        />

        <!-- Border around the stream area -->
        <Rectangle X="80" Y="30" Width="640" Height="480" LineColor="0.3 0.3 0.4" LineWidth="1"/>

        <!-- Instructions -->
        <Text ParentAlignX="#_align_center_" Y="8" LocalAlignX="#_align_center_" Size="10" FillColor="0.4 0.4 0.5">Start server first: python3 server.py</Text>

    </Window>
</DCAPP>
