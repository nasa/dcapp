{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build dcapp-debug (linux)",
      "type": "shell",
      "command": "./build_apps_linux.sh",
      "args": [
        "-c",
        "debug"
      ],
      "options": {
        "cwd": "${workspaceFolder}/scripts"
      },
      "group": "build"
    },
    {
      "label": "build dcapp-debug (macos)",
      "type": "shell",
      "command": "./build_apps_macos.sh",
      "args": [
        "-c",
        "debug"
      ],
      "options": {
        "cwd": "${workspaceFolder}/scripts"
      },
      "group": "build"
    },
    {
      "label": "build dcapp-debug (windows)",
      "type": "shell",
      "command": "./build_apps_windows.bat",
      "args": [
        "-c",
        "debug"
      ],
      "options": {
        "cwd": "${workspaceFolder}/scripts"
      },
      "group": "build"
    },
    {
      "label": "build tests",
      "type": "shell",
      "command": "./tests/build-tests.py",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build"
    }
  ]
}